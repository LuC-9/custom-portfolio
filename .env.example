# GEMINI_API_KEY: Powers the Gemini chatbot and AI blog summaries.
# next.config.mjs exposes this to browser widgets as NEXT_PUBLIC_GEMINI_API_KEY,
# so treat the value as public to site visitors.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# Optional for the active app routes; useful for hosting/platform metadata.
APP_URL="MY_APP_URL"

# Telegram contact delivery. Required for /api/contact and the chatbot
# submitContactForm tool to send messages.
TELEGRAM_BOT_TOKEN="MY_TELEGRAM_BOT_TOKEN"
TELEGRAM_CHAT_ID="MY_TELEGRAM_CHAT_ID"
